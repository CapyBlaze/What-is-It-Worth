{
    "semi": true,
    "singleQuote": false,
    "overrides": [
        {
            "files": ["*.yml"],
            "options": {
                "tabWidth": 2
            }
        }
    ],
    "tabWidth": 4,
    "printWidth": 100,
    "trailingComma": "es5",
    "importOrder": ["^(react|next|node:)(.*)$", "<THIRD_PARTY_MODULES>", "^@/(.*)$", "^[./]"],
    "importOrderSeparation": true,
    "importOrderSortSpecifiers": true
}
